# ==========================================================================
# .env.example — copy to `.env` and fill in the keys you plan to use.
# ==========================================================================
#
# The `.env` file MUST sit at the project root (same folder as
# backtest.py / fire.py / analyze.py). It is read automatically by all
# CLI entry points (backtest.py, fire.py, analyze.py, fetch_data.py)
# and by the Streamlit dashboard. Real shell env vars always win, so
# you can override any of these at runtime with `export FOO=...` on
# macOS/Linux or `$env:FOO = "..."` on PowerShell.
#
# `.env` is in `.gitignore` — your keys never end up in a commit.
# ==========================================================================

# --------------------------------------------------------------------------
# AI provider API keys — set ONLY the one(s) you actually use.
# You pick the provider at runtime with `analyze.py --provider <name>`.
# --------------------------------------------------------------------------

# OpenRouter (default provider — gives access to Anthropic, OpenAI, Google,
# Meta, Mistral, etc. under a single key). Get a key at:
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local (Ollama / vLLM / LM Studio). No key needed. The default endpoint is
# http://localhost:11434/v1 (Ollama). Override the base URL here if you run
# a different server or a non-default port:
# LOCAL_API_BASE_URL=http://localhost:11434/v1

# --------------------------------------------------------------------------
# Optional: override the default model per provider without passing --model
# on the CLI. These are NOT read by the code — to change the model use the
# CLI flag `--model <name>` or the "Model" input in the Streamlit dashboard.
#
# Default models (used when you don't pass --model):
#   openrouter -> anthropic/claude-opus-4-7
#   openai     -> gpt-4o
#   anthropic  -> claude-opus-4-7
#   local      -> kimi-k2-0.6b
# --------------------------------------------------------------------------
