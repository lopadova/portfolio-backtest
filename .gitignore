# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env

# Data (never commit raw data — licensing)
data/raw/*.csv
!data/raw/.gitkeep

# Portfolio presets (user-saved portfolios stay local; shipped presets are
# explicitly whitelisted below)
portfolios/*.toml
!portfolios/four_umbrellas.toml
!portfolios/*.example.toml

# Outputs
output/
!output/.gitkeep

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Jupyter
.ipynb_checkpoints/

# pytest
.pytest_cache/
.coverage
htmlcov/
coverage.xml
